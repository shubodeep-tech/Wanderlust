<% layout("layouts/boilerplate") %>

<!-- FILTER BAR -->
<div class="filters-bar mt-3 px-3">
  <% const categories = [
    ["trending","fa-fire","Trending"],
    ["mountains","fa-mountain","Mountains"],
    ["beaches","fa-umbrella-beach","Beaches"],
    ["iconic_cities","fa-city","Cities"],
    ["rooms","fa-bed","Rooms"],
    ["farms","fa-tractor","Farms"],
    ["camping","fa-campground","Camping"],
    ["castles","fa-chess-rook","Castles"],
    ["arctic","fa-snowflake","Arctic"],
    ["luxury","fa-gem","Luxury"],
    ["nature","fa-tree","Nature"],
    ["lake","fa-water","Lake"]
  ]; %>

  <% categories.forEach(cat => { %>
    <div class="filter" data-category="<%= cat[0] %>">
      <i class="fa-solid <%= cat[1] %>"></i>
      <p><%= cat[2] %></p>
    </div>
  <% }) %>
</div>

<h3 class="mb-4 px-3">All Listings</h3>

<!-- LISTINGS -->
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4 px-3">

  <% if (listings.length === 0) { %>
    <p>No listings found</p>
  <% } %>

  <% listings.forEach(listing => { %>

    <div class="col">
      <div class="card listing-card h-100">

        <!-- IMAGE -->
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <img 
            src="<%= listing.image?.url || '/default.jpg' %>" 
            class="card-img-top"
          />
        </a>

        <!-- WISHLIST -->
        <% if (currUser) { %>
          <form action="/listings/<%= listing._id %>/wishlist" method="POST">
            <button class="wishlist-btn">❤️</button>
          </form>
        <% } %>

        <!-- BODY -->
        <div class="card-body">
          <strong><%= listing.title %></strong><br>

          <span class="price">
            ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
          </span> / night
        </div>

      </div>
    </div>

  <% }) %>

</div>

<script>
document.querySelectorAll(".filter").forEach(el => {
  el.addEventListener("click", () => {
    const category = el.dataset.category;
    window.location.href = `/listings?category=${category}`;
  });
});
</script>