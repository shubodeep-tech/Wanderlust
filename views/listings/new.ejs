<% layout("layouts/boilerplate") %>

<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

      <h3 class="mb-4 text-center">Create a New Listing</h3>

      <form 
        method="POST" 
        action="/listings" 
        enctype="multipart/form-data"
        class="needs-validation"
        novalidate
      >

        <!-- TITLE -->
        <div class="mb-3">
          <label class="form-label">Title</label>
          <input name="listing[title]" type="text" class="form-control" required />
        </div>

        <!-- DESCRIPTION -->
        <div class="mb-3">
          <label class="form-label">Description</label>
          <textarea name="listing[description]" class="form-control" required></textarea>
        </div>

        <!-- IMAGE -->
        <div class="mb-3">
          <label class="form-label">Upload Image</label>
          <input type="file" name="listing[image]" class="form-control" />
        </div>

        <!-- PRICE + COUNTRY -->
        <div class="row">
          <div class="col-md-4 mb-3">
            <label class="form-label">Price</label>
            <input name="listing[price]" type="number" class="form-control" required />
          </div>

          <div class="col-md-8 mb-3">
            <label class="form-label">Country</label>
            <input name="listing[country]" type="text" class="form-control" required />
          </div>
        </div>

        <!-- LOCATION -->
        <div class="mb-3">
          <label class="form-label">Location</label>
          <input name="listing[location]" type="text" class="form-control" required />
        </div>

        <!-- CATEGORY -->
        <div class="mb-3">
          <label class="form-label">Category</label>

          <input id="category" name="listing[category]" type="hidden" required />

          <div class="filters-bar">
            <div class="filter" data-category="trending">🔥 Trending</div>
            <div class="filter" data-category="mountains">🏔 Mountains</div>
            <div class="filter" data-category="beaches">🏖 Beaches</div>
            <div class="filter" data-category="rooms">🛏 Rooms</div>
          </div>
        </div>

        <button type="submit" class="btn btn-dark w-100">
          Add Listing
        </button>

      </form>
    </div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {

  const filters = document.querySelectorAll(".filter");
  const input = document.getElementById("category");

  // SELECT CATEGORY
  filters.forEach(f => {
    f.addEventListener("click", () => {
      filters.forEach(el => el.classList.remove("active"));
      f.classList.add("active");
      input.value = f.dataset.category;
    });
  });


  document.querySelector("form").addEventListener("submit", (e) => {
    if (!input.value) {
      e.preventDefault();
      alert("Please select a category!");
    }
  });

  // 🚀 AUTO DEFAULT (NO EMPTY CATEGORY EVER)
  if (filters.length > 0) {
    filters[0].click();
  }

});
</script>