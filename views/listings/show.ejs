<% layout("layouts/boilerplate") %>

<div class="show-wrapper">

  <!-- TITLE -->
  <h2 class="show-title"><%= listing.title %></h2>

  
  <p class="show-owner">
    Hosted by <strong><%= listing.owner?.username || "Unknown" %></strong>
  </p>

  <!-- IMAGE -->
  <div class="position-relative">
    <img 
      src="<%= listing.image?.url || '/default.jpg' %>" 
      class="show-img"
    />

    <% if (currUser) { %>
      <form action="/listings/<%= listing._id %>/wishlist" method="POST">
        <button class="wishlist-btn">❤️</button>
      </form>
    <% } %>
  </div>

  <!-- INFO -->
  <div class="show-info">

    <p class="show-location">
      📍 <%= listing.location %>, <%= listing.country %>
    </p>

    <p class="show-price">
      ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> / night
    </p>

    <p class="show-desc"><%= listing.description %></p>
  </div>

  <!-- OWNER ACTIONS -->
  <% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
    <div class="btns">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger">Edit</a>

      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-dark">Delete</button>
      </form>
    </div>
  <% } %>

  <!-- REVIEW FORM -->
  <% if (currUser) { %>
    <hr/>
    <h4>Leave a review</h4>

    <form action="/listings/<%= listing._id %>/reviews" method="POST">
      <input type="range" min="1" max="5" name="review[rating]" />
      <textarea name="review[comment]" class="form-control mt-2"></textarea>
      <button class="btn btn-dark mt-2">Submit</button>
    </form>
  <% } %>

  <!-- REVIEWS -->
  <% if (listing.reviews && listing.reviews.length > 0) { %>
    <hr/>
    <h4>All Reviews</h4>

    <% listing.reviews.forEach(review => { %>
      <div class="card review-card mb-3">
        <div class="card-body">
          <h6>@<%= review.author?.username || "Anonymous" %></h6>
          <p><%= review.comment %></p>
          <small>⭐ <%= review.rating %> / 5</small>
        </div>
      </div>
    <% }) %>
  <% } %>

  <!-- MAP -->
  <hr/>
  <h4>Where you'll be</h4>
  <div id="map"></div>

</div>

<script>
  const mapToken = "<%= mapToken %>";
  const listingData = <%- JSON.stringify(listing) %>;
</script>

<script src="/js/map.js"></script>